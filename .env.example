# =============================================================================
# MAMGA-Local — Environment Configuration
# Copy this file to .env and fill in the values that apply to your setup.
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Backend
# Choose one: openai | lmstudio | ollama
# Default: lmstudio  (works out-of-the-box with LM Studio on port 1234)
# -----------------------------------------------------------------------------
LLM_BACKEND=lmstudio

# The model name to use for completions.
# openai    → e.g. gpt-4o-mini, gpt-4o
# lmstudio  → the model identifier shown in LM Studio (e.g. local-model)
# ollama    → e.g. llama3, mistral, phi3
LLM_MODEL=local-model

# Base URL for the LLM server.
# Leave commented out to use the default for your chosen backend:
#   lmstudio → http://localhost:1234/v1
#   ollama   → http://localhost:11434
#   openai   → https://api.openai.com/v1  (set automatically)
# LLM_BASE_URL=http://localhost:1234/v1

# -----------------------------------------------------------------------------
# OpenAI (only needed when LLM_BACKEND=openai)
# -----------------------------------------------------------------------------
# OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# Embedding Model
# Options: minilm (local, default) | openai (requires OPENAI_API_KEY)
# -----------------------------------------------------------------------------
DEFAULT_EMBEDDING_MODEL=minilm

# Sentence-Transformers model name (used when DEFAULT_EMBEDDING_MODEL=minilm)
ENCODER_MODEL=all-MiniLM-L6-v2

# -----------------------------------------------------------------------------
# Cache & Logging
# -----------------------------------------------------------------------------
CACHE_DIR=./cache
LOG_LEVEL=INFO
